# Copy to backend/.env (gitignored) and fill in real values.
# Never commit the populated .env.

# IBM Quantum runtime credentials — token must NEVER leave the backend.
IBM_QUANTUM_TOKEN=
IBM_QUANTUM_INSTANCE=ibm-q/open/main
IBM_QUANTUM_CHANNEL=ibm_quantum

# CORS origin allowed by FastAPI (frontend dev server).
FRONTEND_ORIGIN=http://localhost:3000

# SQLite trials store — relative to backend/ working directory.
TRIALS_DB_PATH=trials.db
